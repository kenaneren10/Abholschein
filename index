<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DocGen 2026 - Abholschein</title>
    <style>
        :root {
            --roche-blue: #0066CC;
            --ui-bg: #f4f7fa;
            --input-border: #d1d9e6;
            --accent-color: #3b82f6;
            --text-dark: #2d3436;
            --shadow: 0 10px 25px rgba(0,0,0,0.05);
        }

        * { box-sizing: border-box; font-family: 'Inter', Segoe UI, Arial, sans-serif; }
        body { margin: 0; background: var(--ui-bg); color: var(--text-dark); display: flex; flex-direction: column; align-items: center; }

        /* --- UI COCKPIT --- */
        #ui-cockpit {
            width: 100%;
            max-width: 1000px;
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(10px);
            margin: 20px;
            padding: 25px;
            border-radius: 16px;
            box-shadow: var(--shadow);
            border: 1px solid rgba(255,255,255,0.3);
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 15px;
            position: sticky;
            top: 10px;
            z-index: 100;
        }

        .input-group { display: flex; flex-direction: column; }
        .input-group label { font-size: 11px; font-weight: 700; text-transform: uppercase; margin-bottom: 5px; color: #7f8c8d; }
        .input-group input { 
            padding: 10px 14px; border: 1.5px solid var(--input-border); border-radius: 8px; font-size: 14px;
            transition: all 0.2s ease; outline: none;
        }
        .input-group input:focus { border-color: var(--accent-color); box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.15); }

        #print-btn {
            grid-column: 1 / -1; background: var(--roche-blue); color: white; border: none; padding: 14px;
            border-radius: 8px; font-weight: 600; cursor: pointer; transition: transform 0.1s; margin-top: 10px;
        }
        #print-btn:hover { filter: brightness(1.1); }
        #print-btn:active { transform: scale(0.98); }

        /* --- PDF PREVIEW (A4) --- */
        #page-container { 
            padding: 20px;
            perspective: 1000px;
        }

        .a4-page {
            width: 210mm;
            height: 297mm;
            background: white;
            box-shadow: 0 0 30px rgba(0,0,0,0.1);
            padding: 15mm 15mm;
            display: flex;
            flex-direction: column;
            position: relative;
            color: black;
            font-size: 10pt;
            font-family: Arial, Helvetica, sans-serif;
            -webkit-print-color-adjust: exact !important;
        }

        /* PDF Typography & Tables */
        .pdf-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 10mm; }
        .id-barcode { font-size: 8pt; letter-spacing: 1px; }
        .doc-title-block { text-align: right; }
        .doc-title-block h1 { font-size: 18pt; margin: 0; font-weight: bold; }
        .doc-title-block p { margin: 2px 0; font-size: 10pt; }

        .address-section { display: grid; grid-template-columns: 1fr 1fr; gap: 10mm; margin-bottom: 5mm; }
        .section-label { font-weight: bold; border-bottom: 1px solid black; margin-bottom: 2mm; display: block; }

        .contact-table { width: 100%; border-collapse: collapse; margin-top: 2mm; }
        .contact-table td { font-size: 9pt; padding: 1px 0; vertical-align: top; }
        .contact-table td:first-child { width: 25mm; font-weight: normal; }

        .freight-unit-header { background: #eee; padding: 2mm; font-weight: bold; margin: 5mm 0; }

        .details-grid { display: grid; grid-template-columns: 1fr 1fr; border: 0.5pt solid black; margin-bottom: 5mm; }
        .grid-item { border: 0.25pt solid #ccc; padding: 2mm; display: flex; flex-direction: column; }
        .grid-item span:first-child { font-size: 8pt; color: #555; }
        .grid-item span:last-child { font-weight: bold; }

        .main-table { width: 100%; border-collapse: collapse; margin-bottom: 10mm; }
        .main-table th { text-align: left; border-bottom: 1pt solid black; font-size: 8pt; padding: 2mm 0; }
        .main-table td { border-bottom: 0.5pt solid #eee; padding: 3mm 0; vertical-align: top; font-size: 9pt; }

        .signature-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10mm; margin-top: auto; }
        .sig-box { border-top: 1pt solid black; padding-top: 1mm; height: 15mm; font-size: 8pt; }

        .footer-logistics { border-top: 1pt solid black; padding-top: 2mm; font-size: 8pt; display: flex; justify-content: space-between; }

        /* PRINT SETTINGS */
        @media print {
            body { background: white; }
            #ui-cockpit { display: none !important; }
            #page-container { padding: 0; margin: 0; }
            .a4-page { box-shadow: none; margin: 0; border: none; }
            @page { size: A4; margin: 0; }
        }
    </style>
</head>
<body>

